// Resource configuration for the LitScan pipeline (litscan.nf).
// These overrides are applied on top of config/cluster.config when running
// the full LitScan pipeline via workflows/litscan/litscan.batch.
//
// Additional env vars required in local.config (not committed):
//   PSYCOPG_CONN     - PostgreSQL URI  (same as PGDB_EMBASSY_USER / PGDATABASE)
//   LITSCAN_MODEL    - absolute path to svc_pipeline.pkl (scikit-learn SVC classifier)
//                      e.g. /path/to/rnacentral-references/training/svc_pipeline.pkl

process {
    queue = 'standard'                          // child jobs go to the standard queue

    // --- search_new_ids ---
    // get_ids runs psql against the embassy DB; lightweight but there are ~18 parallel jobs
    withName: 'get_ids' {
        memory = '512 MB'
        time   = '1h'
    }
    // check_ids / sort_ids: pure file processing, fast
    withName: 'check_ids|sort_ids' {
        memory = '512 MB'
        time   = '30m'
    }
    // prepare_to_submit: deduplication step; 2GB already declared inline
    withName: 'prepare_to_submit' {
        memory = '2 GB'
        time   = '1h'
    }
    // register_ids / register_urs: comm + direct DB INSERT; fast
    withName: 'register_ids|register_urs' {
        memory = '4 GB'
        time   = '4h'
    }

    // --- scan_new_ids ---
    // One SLURM job per RNA ID: loads ML model, queries Europe PMC, writes sentences.
    // Time budget is generous because popular IDs can have hundreds of articles.
    withName: 'scan_job' {
        memory = '4 GB'
        time   = '24h'
    }

    // --- load_organisms ---
    withName: 'download_organism_data' {
        memory = '1 GB'
        time   = '1h'
    }
    withName: 'create_organism_file' {
        memory = '2 GB'
        time   = '1h'
    }
    withName: 'load_organisms_table' {
        memory = '2 GB'
        time   = '2h'
    }

    // --- find_retracted_articles ---
    // Queries Europe PMC REST API in batches; network-bound, not memory-bound
    withName: 'check_articles' {
        memory = '1 GB'
        time   = '2h'
    }

    // --- export_articles ---
    // Most expensive stage: generates XML for all articles; already declared 22GB inline
    withName: 'create_xml_files' {
        memory = '22 GB'
        time   = '6h'
    }

    // --- export_metadata ---
    withName: 'create_metadata' {
        memory = '1 GB'
        time   = '1h'
    }
    withName: 'merge_metadata' {
        memory = '2 GB'
        time   = '1h'
    }
    // create_xml generates metadata XMLs in 500k-entry batches; already declared 2GB inline
    withName: 'create_xml' {
        memory = '2 GB'
        time   = '2h'
    }
    withName: 'load_database_table|save_statistics' {
        memory = '1 GB'
        time   = '1h'
    }
    withName: 'get_statistics' {
        memory = '1 GB'
        time   = '1h'
    }
}

// vim: ft=groovy
