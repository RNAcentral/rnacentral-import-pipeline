params {
  databases {

    biogrid {
      inputs {
        remote = 'https://downloads.thebiogrid.org/Download/BioGRID/Latest-Release/BIOGRID-ALL-LATEST.psi25.zip'
        produces = 'BIOGRID-ALL-LATEST.psi25.zip'
      }
    }

    "5srrnadb" {
      remote = '/nfs/leia/production/xfam/users/bsweeney/provided-data/5srnadb/5srnadb-v1.json'
    }

    circpedia {
      run = false
      annotation_base_url = "https://bits.fudan.edu.cn/circpediav3/static/download_cache/annotation/"
      fasta_base_url = "https://bits.fudan.edu.cn/circpediav3/static/download_cache/sequence/"
      species = [
        [annotation: "Caenorhabditis-elegans",   fasta: "Caenorhabditis_elegans_circ",  assembly: "WBcel235"],
        [annotation: "Canis-lupus-familiaris",   fasta: "Canis_lupus_familiaris_circ",  assembly: "ROS_Cfam_1.0"],
        [annotation: "Cavia-porcellus",          fasta: "Cavia_porcellus_circ",         assembly: "Cavpor3.0"],
        [annotation: "Cercocebus-atys",          fasta: "Cercocebus_atys_circ",         assembly: "Caty_1.0"],
        [annotation: "Callithrix-jacchus",       fasta: "Callithrix_jacchus_circ",      assembly: "mCalJac1.pat.X"],
        [annotation: "Drosophila-melanogaster",  fasta: "Drosophila_melanogaster_circ", assembly: "BDGP6"],
        [annotation: "Felis-catus",              fasta: "Felis_catus_circ",             assembly: "Felis_catus_9.0"],
        [annotation: "Gallus-gallus",            fasta: "Gallus_gallus_circ",           assembly: "GRCg7b"],
        [annotation: "Homo-sapiens",             fasta: "Homo_sapiens_circ",            assembly: "GRCh38"],
        [annotation: "Macaca-fascicularis",      fasta: "Macaca_fascicularis_circ",     assembly: "Macaca_fascicularis_6.0"],
        [annotation: "Macaca-mulatta",           fasta: "Macaca_mulatta_circ",          assembly: "Mmul_10"],
        [annotation: "Macaca-nemestrina",        fasta: "Macaca_nemestrina_circ",       assembly: "Mnem_1.0"],
        [annotation: "Mus-musculus",             fasta: "Mus_musculus_circ",            assembly: "GRCm38"],
        [annotation: "Oryctolagus-cuniculus",    fasta: "Oryctolagus_cuniculus_circ",   assembly: "OryCun2.0"],
        [annotation: "Ovis-aries",              fasta: "Ovis_aries_circ",              assembly: "Oar_v3.1"],
        [annotation: "Papio-anubis",             fasta: "Papio_anubis_circ",            assembly: "Panubis1.0"],
        [annotation: "Pongo-abelii",             fasta: "Pongo_abelii_circ",            assembly: "Susie_PABv2"],
        [annotation: "Pan-troglodytes",          fasta: "Pan_troglodytes_circ",         assembly: "pan_Tro_3.0"],
        [annotation: "Rattus-norvegicus",        fasta: "Rattus_norvegicus_circ",       assembly: "mRatBN7.2"],
        [annotation: "Sus-scrofa",              fasta: "Sus_scrofa_circ",              assembly: "Sscrofa11.1"],
      ]
  }

    crw {
      r2dt_repo = "https://github.com/RNAcentral/R2DT.git"
    }

    ena {
      remote = '/nfs/ftp/public/databases/ena/non-coding/snapshot_latest'
      max_sequences = 50000
    }

    ensembl {
      gencode {
        ftp_host = 'ftp.ebi.ac.uk'
      }

      vertebrates {
        ftp_host = 'ftp.ensembl.org'
        exclude = [
          /mus_musculus_.*/,
          /caenorhabditis_elegans.*/,
          /drosophila_melanogaster.*/,
          /saccharomyces_cerevisiae.*/,
          /cebus_capucinus/,
          /cyprinus_carpio_.*/,
        ]
      }

      rapid_release {
        ftp = 'ftp://ftp.ensembl.org/pub/rapid-release/embl'
      }

      plants {
        ftp_host = 'ftp.ensemblgenomes.org'
        exclude = [
          /cyanidioschyzon_merolae.*/
        ]
      }

      fungi {
        ftp_host = 'ftp.ensemblgenomes.org'
        exclude = [
          /saccharomyces_cerevisiae.*/,
          /schizosaccharomyces_pombe.*/,
        ]
      }

      protists {
        ftp_host = 'ftp.ensemblgenomes.org'
        exclude = []
      }

      metazoa {
        ftp_host = 'ftp.ensemblgenomes.org'
        exclude = [
          /caenorhabditis_elegans.*/,
          /drosophila_melanogaster.*/,
        ]
      }

      compara {
        remote = 'ftp://ftp.ensembl.org/pub/current_emf/ensembl-compara/homologies/*.nt.fasta.gz'
      }
    }

    expressionatlas {
      cache = '/hps/nobackup/agb/rnacentral/expression_atlas_cache'
    }

    flybase {
      remote = 'https://s3ftp.flybase.org/releases/current/precomputed_files/genes/ncRNA*.json.gz'
    }

    genecards {
      remote = ''
      column = 'URSid'
    }

    gtrnadb {
      needs_taxonomy = true
      remote = 'https://trna.ucsc.edu/download/RNAcentral/export2023/gtrnadb_r20_export.tar.gz'
    }

    hgnc {
      remote = 'https://storage.googleapis.com/public-download-files/hgnc/json/json/locus_groups/non-coding_RNA.json'
    }

    intact {
      remote = 'ftp://ftp.ebi.ac.uk/pub/databases/intact/current/psimitab/intact.zip'
    }

    japonicusdb {
      remote = 'https://www.japonicusdb.org/data/releases/latest/misc/rnacentral.json'
    }

    lncbase {
      remote = '/nfs/production/agb/rnacentral/provided-data/lncbase/LncBase2.json'
    }

    lncbook {
      process.directives.memory = 5.GB
      remote = "/nfs/production/agb/rnacentral/provided-data/lncbook/LncBookv2.0_GRCh38_RNAcentral.json"
    }

    lncipedia {
      run = false
      process.directives.memory = 5.GB
      remote = "https://lncipedia.org/downloads/lncipedia_5_3/lncipedia_5_3_rnacentral.json"
    }

    malacards {
      remote = ''
      column = 'URSid'
    }

    mirbase {
      process.directives.memory = 4.GB
      remote = "/nfs/production/agb/rnacentral/provided-data/mirbase/mirbase22rnacentral.20180523.json"
    }

    mirgenedb {
      remote = '/nfs/production/agb/rnacentral/provided-data/mirgenedb/mirgenedb-v3.json'
    }

    mirtrondb {
      remote = '/nfs/production/agb/rnacentral/provided-data/mirtrondb/all_organisms_both.tsv'
    }

    modomics {
      remote = '/nfs/production/agb/rnacentral/provided-data/modomics/modomics-2025-09-16.json'
    }

    ncbi_gene {
      inputs {
        data_file {
          command = 'rnac ncbi fetch-genes'
          produces = 'ncbi-genes.pickle'
        }
      }
    }

    pdb {
      run = false
    }

    pirbase {
      remote = 'http://www.regulatoryrna.org/database/piRNA/forJSON.html'
    }

    pombase {
      remote = 'https://www.pombase.org/data/releases/latest/misc/rnacentral.json'
    }

    psicquic {
      remote = ''
    }

    silva {
      needs_taxonomy = true
      remote = 'http://ftp.arb-silva.de/current/Exports/rnac/'
    }

    snodb {
      remote = '/nfs/production/agb/rnacentral/provided-data/snodb/snodb-v2.json'
    }

    snorna_database {
      remote = '/nfs/leia/production/xfam/users/bsweeney/provided-data/snorna_database/snornadb-2019-11-11.json'
    }

    quickgo {
      release = false
      memory = 8.GB
      remote = '/nfs/ftp/public/contrib/goa/goa_rna_all.gpa.gz'
    }

    rediportal {
      bed_remote = 'http://srv00.recas.ba.infn.it/webshare/redidata/REDI_sorted.bed'
      meta_remote = 'http://srv00.recas.ba.infn.it/webshare/ATLAS/donwload/TABLE1_hg38.txt.gz'
      chunk_size = 1024 * 1000 * 1000
    }

    refseq {
      remote = 'https://ftp.ncbi.nlm.nih.gov/refseq/release/complete/'
    }

    ribovision {
      remote = 'http://apollo.chemistry.gatech.edu/RiboVision2/rnacentral_mapping.html'
    }

    ribocentre {
      remote = 'https://github.com/aoying35/Ribocentre-data/raw/refs/heads/main/ribocentre.json'
    }

    rfam {
     remote = '/hps/nobackup/production/xfam/rfam/RELEASES/14.1/rnacentral/json_files/rfam2rnac*.json'
    }

    rgd {
      sequences = 'https://download.rgd.mcw.edu/pub/data_release/UserReqFiles/RAT_NUCLEOTIDE_SEQUENCES.fa.gz'
      genes = 'https://download.rgd.mcw.edu/pub/data_release/GENES_RAT.txt'
    }

    sgd {
      remote = "https://downloads.yeastgenome.org/latest/RNAcentral.json"
    }

    tmrna {
      data = '/nfs/production/agb/rnacentral/provided-data/tmrna/tmrna.tsv'
    }

    tarbase {
      remotes = [
        'https://dianalab.e-ce.uth.gr/tarbasev9/data/Homo_sapiens_TarBase-v9.tsv.gz',
        'https://dianalab.e-ce.uth.gr/tarbasev9/data/Mus_musculus_TarBase-v9.tsv.gz',
        'https://dianalab.e-ce.uth.gr/tarbasev9/data/Viral_species_TarBase-v9.tsv.gz',
        'https://dianalab.e-ce.uth.gr/tarbasev9/data/Other_species_TarBase-v9.tsv.gz'
      ]
    }

    zfin {
      remote = 'https://zfin.org/downloads/rnaCentral.json'
    }

    zwd {
      needs_taxonomy = true
      remote = 'https://raw.githubusercontent.com/Rfam/rfam-zwd-import/master/zwd.json'
    }
  }
}
