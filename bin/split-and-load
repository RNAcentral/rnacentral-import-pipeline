#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

ctl="$1"
input_name="$2"
size="$3"
split_name="${4:-data}"
split_ext="${5:-csv}"

merged="$split_name-merged"

[ ! -d "$merged" ] || rm -r "$merged"
mkdir "$merged"
find . -name "$input_name" |
xargs cat |
split --additional-suffix=".$split_ext" -dC $size - "$merged/$split_name"

cp $ctl "$merged/$ctl"
pushd "$merged"
if compgen -G "$split_name*.$split_ext" > /dev/null; then
  tmp="pgloader-output"
  max_attempts=3
  for attempt in $(seq 1 $max_attempts); do
    pgloader_exit=0
    pgloader --dynamic-space-size 4096 --on-error-stop $ctl | tee "$tmp" || pgloader_exit=$?
    if [ $pgloader_exit -eq 0 ]; then
      break
    fi
    if [ $attempt -lt $max_attempts ]; then
      echo "pgloader failed (attempt $attempt/$max_attempts), retrying in 10s..."
      sleep 10
    else
      exit $pgloader_exit
    fi
  done
  rnac validate-pgloader "$tmp"
fi
popd
